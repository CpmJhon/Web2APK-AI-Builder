{
  "functions": {
    "api/generate-apk.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/scan-website.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/github-export.ts": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, X-Requested-With"
        },
        {
          "key": "Access-Control-Max-Age",
          "value": "86400"
        }
      ]
    },
    {
      "source": "/(.*\\.(apk|zip))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/builder",
      "destination": "/app/builder",
      "permanent": true
    },
    {
      "source": "/dashboard",
      "destination": "/app/dashboard",
      "permanent": true
    }
  ],
  "build": {
    "env": {
      "NEXT_PUBLIC_VERCEL_URL": "@next_public_vercel_url"
    }
  },
  "regions": ["sin1", "iad1"],
  "cleanUrls": true,
  "trailingSlash": false,
  "github": {
    "silent": true
  }
}